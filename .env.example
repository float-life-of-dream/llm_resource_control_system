DATABASE_URL=postgresql+psycopg://ai_monitor:ai_monitor@postgres:5432/ai_monitor
FRONTEND_ORIGIN=http://localhost:8080,http://localhost:5173
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
BOOTSTRAP_ADMIN_EMAIL=admin@example.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_DEFAULT_TENANT_NAME=Default Tenant
BOOTSTRAP_DEFAULT_TENANT_SLUG=default
# Real Prometheus by default. This repo can run an internal Prometheus collector stack.
# For local demo mode use http://mock-prometheus:9090 instead.
PROMETHEUS_BASE_URL=http://prometheus:9090
PROMETHEUS_TIMEOUT=5
OLLAMA_BASE_URL=http://ollama-exporter:9500
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=30
OLLAMA_EXPORTER_TARGET_URL=http://host.docker.internal:11434
OLLAMA_EXPORTER_TIMEOUT=10
OLLAMA_EXPORTER_PORT=9500
ELASTICSEARCH_BASE_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX=logs-*
ELASTICSEARCH_TIMEOUT=10
ANALYSIS_LOG_LIMIT_DEFAULT=50
ANALYSIS_LOG_LIMIT_MAX=200
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_monitor
POSTGRES_USER=ai_monitor
POSTGRES_PASSWORD=ai_monitor
